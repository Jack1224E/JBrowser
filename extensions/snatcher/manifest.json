{
  "manifest_version": 3,
  "name": "Pir Downloader",
  "version": "2.2",
  "key": "",
  "description": "High-performance pirate loot fetcher for Pir Browser.",
  "permissions": [
    "downloads",
    "nativeMessaging",
    "storage",
    "webRequest"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icons/icon128.png"
  },
  "icons": {
    "128": "icons/icon128.png"
  }
}
