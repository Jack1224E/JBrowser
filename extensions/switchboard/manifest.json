{
  "manifest_version": 3,
  "name": "Pirate Switchboard",
  "version": "1.0",
  "key": "",
  "description": "Zero-Setup Proxy Switchboard for the Pir Browser.",
  "permissions": [
    "proxy",
    "storage",
    "tabs"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png"
  },
  "icons": {
    "128": "icon.png"
  }
}
